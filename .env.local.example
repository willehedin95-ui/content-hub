# Supabase (get from supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI (get from platform.openai.com → API Keys)
OPENAI_API_KEY=sk-...

# Cloudflare Pages (get from dash.cloudflare.com → your account)
CF_PAGES_ACCOUNT_ID=        # Account ID (right sidebar on dashboard)
CF_PAGES_API_TOKEN=         # API token with Cloudflare Pages Edit permission
CF_PAGES_PROJECT_SV=        # Pages project name for Swedish (blog.halsobladet.com)
CF_PAGES_PROJECT_DA=        # Pages project name for Danish (smarthelse.dk)
CF_PAGES_PROJECT_NO=        # Pages project name for Norwegian (helseguiden.com)
CF_PAGES_DOMAIN_SV=         # Custom domain for Swedish (e.g. blog.halsobladet.com)
CF_PAGES_DOMAIN_DA=         # Custom domain for Danish (e.g. smarthelse.dk)
CF_PAGES_DOMAIN_NO=         # Custom domain for Norwegian (e.g. helseguiden.com)

# App URL (public URL of this dashboard, used for A/B test tracking pixels)
APP_URL=https://your-app.vercel.app

# Meta Marketing API (get from Meta Business Manager → System Users)
META_SYSTEM_USER_TOKEN=    # Long-lived System User access token
META_AD_ACCOUNT_ID=        # Ad Account ID (without 'act_' prefix)
META_PAGE_ID=              # Facebook Page ID for ad creatives

# Kie AI (get from kie.ai → Dashboard → API Keys)
KIE_AI_API_KEY=            # API key for image translation

# Resend (get from resend.com → API Keys)
RESEND_API_KEY=re_...      # Email notification delivery

# Google Drive (service account for import/export)
GDRIVE_SERVICE_ACCOUNT_EMAIL=  # Service account email (xxx@xxx.iam.gserviceaccount.com)
GDRIVE_PRIVATE_KEY=            # Service account private key (PEM format, with \n)

# Google Drive (OAuth for user-context uploads + Google Ads auth)
GDRIVE_OAUTH_CLIENT_ID=        # OAuth 2.0 Client ID
GDRIVE_OAUTH_CLIENT_SECRET=    # OAuth 2.0 Client Secret
GDRIVE_OAUTH_REFRESH_TOKEN=    # Offline refresh token for Drive uploads

# Google Ads (REST API v18 — uses GDRIVE_OAUTH_* for auth)
GOOGLE_ADS_DEVELOPER_TOKEN=    # Developer token from Google Ads API Center
GOOGLE_ADS_CUSTOMER_ID=        # Customer ID (without dashes, e.g. 1234567890)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=  # MCC/Manager account ID (if using manager account)

# Klaviyo (get from klaviyo.com → Account → Settings → API Keys)
KLAVIYO_API_KEY=               # Private API key for metrics and revenue tracking

# Vercel Cron (daily snapshots)
CRON_SECRET=                   # Random secret for cron endpoint auth

# Auth (comma-separated Google emails allowed to log in)
ALLOWED_EMAILS=user@gmail.com,other@gmail.com
